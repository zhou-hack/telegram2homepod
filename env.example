# ── Telegram (Optional, leave empty to start WebUI only) ──
BOT_TOKEN=
ALLOWED_USERS=

# ── HomePod (Required) ──
HOMEPOD_ID=
HOMEPOD_IP=

# ── HTTP File Service (Used by HomePod to stream audio, set to your server LAN IP) ──
HTTP_HOST=
HTTP_PORT=8765

# ── Storage Directories (Leave empty to use music/ and history/ in the project folder) ──
# Windows example: DOWNLOAD_DIR=C:\homepod\music
DOWNLOAD_DIR=
HISTORY_DIR=
CACHE_MAX=20

# ── WebUI ──
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

# WEBUI_TOKEN will be generated automatically on first startup and written to this file.
# Access URL: http://IP:8080/?token=xxx  or enter the token in the login page
WEBUI_TOKEN=
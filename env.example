# Telegram (Optional)
BOT_TOKEN=
ALLOWED_USERS=

# HomePod Private IP Address
HOMEPOD_ID=
HOMEPOD_IP=

# HTTP File Service
HTTP_HOST=
HTTP_PORT=8765

# ── Storage Directories (leave empty to automatically use music/ and history/ inside the project directory) ──
# Windows example: DOWNLOAD_DIR=C:\homepod\music
DOWNLOAD_DIR=
HISTORY_DIR=
CACHE_MAX=20

# ── WebUI ──
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080
# WEBUI_TOKEN will be automatically generated and written to this file on first startup, no need to fill manually
# Access: http://IP:8080/?token=xxx  or enter the token in the login page
WEBUI_TOKEN=